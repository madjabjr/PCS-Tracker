# JWT
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Local admin fallback
# Generate hash with: python scripts/hash_password.py
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your_bcrypt_password_hash_here
ADMIN_EMAIL=your_admin_email@example.com

# URLs
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./pcs_tracker.db

# Optional: AviationStack flight data (https://aviationstack.com/)
AVIATIONSTACK_API_KEY=your_aviationstack_api_key_here
